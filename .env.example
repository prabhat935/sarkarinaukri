# Google Analytics & AdSense Configuration
# Copy this file to .env and update with your actual values

# Google Analytics ID (format: G-XXXXXXXXXX)
# Get this from: https://analytics.google.com
GOOGLE_ANALYTICS_ID=

# Google AdSense Client ID (format: ca-pub-xxxxxxxxxxxxxxxx)
# Get this from: https://www.google.com/adsense/
GOOGLE_ADSENSE_CLIENT_ID=

# Enable/Disable AdSense (set to "True" to enable)
GOOGLE_ADSENSE_ENABLED=False

# Optional: Additional monetization settings
# SECRET_KEY=your-secret-key-here
# DEBUG=False
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
